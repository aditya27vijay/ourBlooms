{
  "name": "ourblooms-server",
  "version": "1.0.0",
  "description": "Backend API for ourBlooms flower e-commerce platform",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo",
